{
  "name": "Small Goods Competition Management",
  "short_name": "SGCompetition",
  "description": "Offline-capable competition management system for small goods weightlifting competitions",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#1a73e8",
  "background_color": "#ffffff",
  "lang": "en",
  "scope": "/",
  "categories": ["sports", "productivity", "utilities"],
