  "shortcuts": [
    {
      "name": "Admin Dashboard",
      "short_name": "Admin",
      "description": "Competition operator dashboard",
      "url": "/admin",
      "icons": [
        {
          "src": "/static/images/shortcut-admin.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Referee Interface",
      "short_name": "Referee",
      "description": "Judge lift attempts",
      "url": "/ref",
      "icons": [
        {
          "src": "/static/images/shortcut-referee.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Timekeeper",
      "short_name": "Timer",
      "description": "Manage competition timer",
      "url": "/tc",
      "icons": [
        {
          "src": "/static/images/shortcut-timer.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Display Board",
      "short_name": "Display",
      "description": "Public scoreboard display",
      "url": "/display",
      "icons": [
        {
          "src": "/static/images/shortcut-display.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "screenshots": [
    {
      "src": "/static/images/screenshot-admin.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Admin Dashboard showing competition overview"
    },
    {
      "src": "/static/images/screenshot-referee.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Referee interface for making decisions"
    },
    {
      "src": "/static/images/screenshot-display.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Public display board for audiences"
    }
  ],
  "features": [
    "offline-support",
    "real-time-updates",
    "multi-role-access",
    "touch-optimized"
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "protocol_handlers": [
    {
      "protocol": "web+sgcompetition",
      "url": "/network?action=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [".json"],
        "text/csv": [".csv"]
      }
    }
  ]
}